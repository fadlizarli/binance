# ─── .env untuk Multi-pair ───
# Salin setting ini ke ~/binance/.env saat siap multi-pair

# Pair yang ingin ditrading (pisah koma, tanpa spasi)
SYMBOLS=SOLUSDT,DOGEUSDT

# Setting umum (sama seperti sekarang)
TIMEFRAME=1h
STRATEGY=trend_following
LEVERAGE=3
RISK_PER_TRADE=1.0
SL_ATR_MULTIPLIER=1.5
RR_RATIO=2.0

# Max drawdown per hari (total semua pair)
MAX_DAILY_DRAWDOWN=10.0

# Max trade per hari (total semua pair, 2 per pair × 2 pair = 4)
MAX_TRADES_PER_DAY=4

# Mode
TRADE_MODE=live

# Telegram
TELEGRAM_BOT_TOKEN=token_kamu
TELEGRAM_CHAT_ID=id_kamu

# Claude API
ANTHROPIC_API_KEY=key_kamu
CLAUDE_FILTER_ENABLED=true

